{
  "controlled_vocabulary": {
    "projects": [
      "Nouverse",
      "gading.dev",
      "Homelab"
    ],
    "technologies": [
      "Kubernetes",
      "Docker",
      "Nginx",
      "Terraform",
      "Proxmox",
      "Cloudflare",
      "Traefik",
      "Redis",
      "PostgreSQL",
      "LangChain",
      "React",
      "Next.js",
      "Ethers.js",
      "Wagmi",
      "NestJS",
      "Flask",
      "Tanstack"
    ]
  },
  "mood_taxonomy": {
    "allowed": [
      "productive",
      "focused",
      "playful",
      "calm",
      "stressed",
      "tired",
      "sad",
      "mixed"
    ],
    "default": "mixed"
  },
  "link_mappings": {
    "people": {
      "ding": "Gading",
      "gading": "Gading",
      "kak rina": "Kak Rina",
      "nadine": "Nadine",
      "nouva": "Nouva",
      "rina": "Kak Rina",
      "va": "Nouva"
    },
    "projects": {
      "gading-dev": "gading.dev",
      "gading.dev": "gading.dev",
      "homelab": "Homelab",
      "nouverse": "Nouverse",
      "nouverse core": "Nouverse",
      "nouverse-core": "Nouverse"
    }
  },
  "retrieval": {
    "decay_constant": 0.005,
    "vector_search_limit": 10,
    "default_semantic_score": 0.5,
    "max_graph_depth": 2,
    "related_date_score_decay": 0.7,
    "default_importance": 5,
    "invalid_date_fallback_days": 365,
    "keyword_boost": {
      "unique_match_weight": 0.02,
      "frequency_weight": 0.005,
      "frequency_cap": 20
    },
    "weights": {
      "importance": 0.3,
      "recency": 0.2,
      "semantic": 0.5
    }
  },
  "max_related_dates": 2,
  "memory_paths": {
    "active_memory_dir": "<path_to_your_active_memory_directory>",
    "archived_memory_dir": "<path_to_your_archived_memory_directory>"
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "agent_db",
    "user": "postgres",
    "password": "devpassword",
    "url": ""
  },
  "embedding": {
    "url": "http://localhost:11434",
    "model": "bge-m3:latest"
  },
  "llm": {
    "url": "http://localhost:3000/v1/chat/completions",
    "model": "gemini-3.5-flash-low",
    "timeout_seconds": 60
  },
  "chunking": {
    "max_chunk_size": 1000,
    "overlap": 100
  },
  "multi_level_index_threshold_entries": 1000,
  "multi_level_index_threshold_kb": 500
}
